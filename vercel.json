{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.ts" },
    { "source": "/uploads/(.*)", "destination": "/api/server.ts" },
    { "source": "/(.*)", "destination": "/api/server.ts" }
  ]
}
